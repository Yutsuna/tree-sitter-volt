@[External]
abstract def __volt_regex_match( regex : Regex, str : UInt8*, size : UInt64 ) -> Int64

struct Regex include Inspectable

  #----------------------------------------------------------------------------

  def matches?( other : String ) -> Bool
    __volt_regex_match( self, other.data, other.size ) != 0
  end

  #----------------------------------------------------------------------------

  def to_string() -> String
    "TODO"
  end

  #----------------------------------------------------------------------------

end
